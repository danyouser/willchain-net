# Phoenix Observer Configuration
# Copy to .env and fill in your values

# ============ Required ============

# Base mainnet RPC (or use Alchemy/QuickNode for reliability)
RPC_URL=https://mainnet.base.org

# PhoenixLegacy contract address (set after deployment)
PHOENIX_CONTRACT_ADDRESS=0x...

# Your wallet private key (for personal_observer.py)
# WARNING: Keep this secret! Never commit to git!
# Format: 0x followed by 64 hex characters
PRIVATE_KEY=0x<your-64-hex-chars>

# Your wallet public address
WALLET_ADDRESS=0x...

# ============ Optional ============

# Check interval in seconds (default: 1 hour)
CHECK_INTERVAL=3600

# Comma-separated list of wallet addresses to monitor (for phoenix_observer.py)
WATCH_ADDRESSES=0x...,0x...

# Telegram notifications
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=-100123456789
