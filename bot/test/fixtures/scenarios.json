[
  {
    "id": "wallet_link_01_valid_link",
    "category": "wallet-link",
    "description": "Valid wallet link: address + valid signature saves user with notifications enabled",
    "input": {
      "telegramId": 100001,
      "walletAddress": "0x742d35Cc6634C0532925a3b844Bc9e7595f2bD18",
      "nonce": "0xabcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890",
      "signature": "0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234"
    },
    "expected": {
      "success": true,
      "userSaved": true,
      "notificationsEnabled": true,
      "walletAddress": "0x742d35Cc6634C0532925a3b844Bc9e7595f2bD18"
    }
  },
  {
    "id": "wallet_link_02_invalid_signature",
