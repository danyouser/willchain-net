# WillChain Telegram Bot Configuration

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# WillChain contract address (Base Sepolia)
CONTRACT_ADDRESS=0x6fAd1475B41731E3eDA21998417Cb2e18E795877

# RPC URL
RPC_URL=https://sepolia.base.org

# Frontend URL for check-in links
FRONTEND_URL=https://willchain.net

# Block explorer base URL (for wallet links in bot messages)
# Base Sepolia: https://sepolia.basescan.org
# Base Mainnet: https://basescan.org
EXPLORER_URL=https://sepolia.basescan.org

# REQUIRED: Block number when the contract was deployed (for full event history on first run).
# If left as 0, the bot only scans the last EVENT_CATCHUP_BLOCKS blocks — events older than
# that window will be PERMANENTLY MISSED (users won't receive notifications for past activity).
# Find the deployment block on Basescan (contract's first transaction).
DEPLOYMENT_BLOCK=0

# Fallback scan window if DEPLOYMENT_BLOCK=0 (~69 days on Base at 2s/block = 500_000 blocks)
EVENT_CATCHUP_BLOCKS=10000

# Auto-recycle: earn 1% reward by recycling ABANDONED nodes (optional)
# Requires a funded wallet on Base to send transactions.
RECYCLE_ENABLED=false
PRIVATE_KEY=0xyour_private_key_here

# HTTP API port (used by frontend to query successor relationships)
API_PORT=3001

# Resend.com API key for email notifications (optional)
RESEND_API_KEY=re_your_api_key_here

# From address for emails (must be a verified domain in Resend)
EMAIL_FROM=WillChain <notifications@willchain.net>
