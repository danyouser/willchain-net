# Copy this file to .env and fill in the values
# WARNING: Never commit .env to git!

# Gemini API key (for translations via scripts/translate-langs.mjs)
GEMINI_API_KEY=

# Deployment private key (WITH 0x prefix, e.g. 0xabc123...)
# ⚠️  Generate a NEW dedicated wallet for mainnet — never reuse testnet key
PRIVATE_KEY=

# RPC URLs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# Basescan API key for contract verification
# Get at: https://basescan.org/myapikey
BASESCAN_API_KEY=

# Treasury address — Gnosis Safe multisig (REQUIRED for mainnet deploy)
# Create at: https://app.safe.global (Base network)
# Minimum 2-of-3 signers on separate devices
TREASURY_ADDRESS=
